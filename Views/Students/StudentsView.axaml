<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:m="using:AcademicRegistry.Models.Entities"
    xmlns:vm="using:AcademicRegistry.ViewModels.Students"
    x:DataType="vm:StudentsViewModel"
    x:Class="AcademicRegistry.Views.Students.StudentsView"
    Padding="15">

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="*, Auto"
        RowSpacing="15">

        <ListBox
            Grid.Row="0"
            ItemsSource="{Binding Students}"
            SelectedItem="{Binding Student}">

            <ListBox.ItemTemplate>

                <DataTemplate x:DataType="m:Student">

                    <Grid ColumnDefinitions="*, *, *">

                        <!-- ReSharper disable Xaml.InvalidType -->
                        <TextBlock
                            Grid.Column="0"
                            HorizontalAlignment="Center"
                            Text="{Binding Name}" />

                        <TextBlock
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            Text="{Binding Surname}" />

                        <TextBlock
                            Grid.Column="2"
                            HorizontalAlignment="Center"
                            Text="{Binding Patronymic}" />
                        <!-- ReSharper restore Xaml.InvalidType -->

                    </Grid>

                </DataTemplate>

            </ListBox.ItemTemplate>

        </ListBox>

        <Grid
            Grid.Row="1"
            ColumnDefinitions="*, *, *">

            <Button
                HorizontalAlignment="Center"
                Width="150"
                Height="50"
                Grid.Column="0"
                Content="Добавить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding AddCommand}" />

            <Button
                HorizontalAlignment="Center"
                Grid.Column="1"
                Width="150"
                Height="50"
                Content="Обновить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding UpdateCommand}" />

            <Button
                HorizontalAlignment="Center"
                Grid.Column="2"
                Width="150"
                Height="50"
                Content="Удалить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding DeleteCommand}" />

        </Grid>

    </Grid>

</UserControl>