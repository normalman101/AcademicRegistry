<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AcademicRegistry.ViewModels.Subjects"
    x:DataType="vm:SubjectInformationEditorViewModel"
    x:Class="AcademicRegistry.Views.Subjects.SubjectInformationEditorView"
    Padding="15">

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto, *"
        RowSpacing="15">

        <TextBox
            Grid.Row="0"
            PlaceholderText="Название"
            Text="{Binding Name}" />

        <Grid
            Grid.Row="1"
            ColumnDefinitions="*, *"
            VerticalAlignment="Bottom">

            <Button
                Grid.Column="0"
                HorizontalAlignment="Center"
                Width="150"
                Height="50"
                Content="Сохранить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding SaveCommand}" />

            <Button
                Grid.Column="1"
                HorizontalAlignment="Center"
                Width="150"
                Height="50"
                Content="Отменить"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Command="{Binding CancelCommand}" />

        </Grid>

    </Grid>

</UserControl>