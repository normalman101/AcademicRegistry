<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AcademicRegistry.ViewModels.Subjects"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:DataType="vm:SubjectInformationEditorViewModel"
    x:Class="AcademicRegistry.Views.Subjects.SubjectInformationEditorView">

    <StackPanel
        Orientation="Vertical"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        Spacing="5">

        <Button
            Content="Назад"
            Command="{Binding ToSubjectsViewCommand}" />

        <TextBox
            PlaceholderText="Название"
            Text="{Binding Name}" />

        <Button
            HorizontalAlignment="Center"
            Content="Сохранить"
            Command="{Binding SaveCommand}" />

    </StackPanel>

</UserControl>