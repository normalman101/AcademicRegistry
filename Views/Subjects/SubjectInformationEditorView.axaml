<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AcademicRegistry.ViewModels.Subjects"
    x:DataType="vm:SubjectInformationEditorViewModel"
    x:Class="AcademicRegistry.Views.Subjects.SubjectInformationEditorView"
    Padding="15">

    <Grid
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        RowDefinitions="Auto, *">

        <TextBox
            Grid.Row="0"
            PlaceholderText="Название"
            Text="{Binding Name}" />

        <Button
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Content="Сохранить"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Width="150"
            Height="50"
            Command="{Binding SaveCommand}" />

    </Grid>

</UserControl>