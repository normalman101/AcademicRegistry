<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AcademicRegistry.ViewModels"
    x:DataType="vm:WindowViewModel"
    x:Class="AcademicRegistry.Views.WindowView"
    WindowStartupLocation="CenterScreen"
    Width="800"
    Height="600"
    Icon="/Assets/avalonia-logo.ico"
    Title="">

    <Grid
        RowDefinitions="Auto, *"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <Menu
            Grid.Row="0"
            BorderBrush="LightGray"
            BorderThickness="0, 0, 0, 2">
            <MenuItem
                Header="Студенты"
                Command="{Binding ToStudentsViewCommand}" />
            <MenuItem
                Header="Предметы"
                Command="{Binding ToSubjectsViewCommand}" />
        </Menu>

        <ContentControl
            Grid.Row="1"
            Content="{Binding CurrentViewModel}" />

    </Grid>

</Window>