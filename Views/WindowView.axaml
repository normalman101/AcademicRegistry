<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AcademicRegistry.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
    x:Class="AcademicRegistry.Views.WindowView"
    x:DataType="vm:WindowViewModel"
    Icon="/Assets/avalonia-logo.ico"
    Title="">

    <Grid
        RowDefinitions="Auto, Auto"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">

        <Menu
            Grid.Row="0"
            BorderBrush="LightGray"
            BorderThickness="0, 0, 0, 2">
            <MenuItem Header="Домой" Command="{Binding ToHomeViewCommand}" />
            <MenuItem Header="Студенты" Command="{Binding ToStudentsViewCommand}" />
            <MenuItem Header="Предметы" Command="{Binding ToSubjectsViewCommand}" />
        </Menu>

        <ContentControl
            Margin="15"
            Grid.Row="1"
            Content="{Binding CurrentPage}" />

    </Grid>

</Window>